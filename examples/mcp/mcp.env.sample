# UAI MCP — örnek env parçası. İlgili satırları .env dosyana kopyala.
# (Dosya adı bilerek ".env*" değil; dotfile koruması olan editörlerde açılabilsin diye.)

# ── MCP İSTEMCİSİ: dış araçları ajanlara kazandır ─────────────────────────────

# Tek stdio sunucu (basit yol)
# MCP_ENABLED=true
# MCP_SERVER_NAME=filesystem
# MCP_SERVER_COMMAND=npx
# MCP_SERVER_ARGS=-y @modelcontextprotocol/server-filesystem /tmp
# MCP_INIT_TIMEOUT_MS=15000

# Çoklu sunucu (stdio + http) — JSON dizisi; bkz. examples/mcp/mcp-servers.json
# MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]

# Hangi ajanlar MCP araçlarını görsün? (boş=tümü, csv, "none", "all")
# MCP_AGENTS=brain,ops

# ── MCP SUNUCUSU: UAI'yi dışa sun (pnpm mcp:serve) ────────────────────────────

# uai_run_bash allowlist önekleri (varsayılan: hepsi RED)
# MCP_SERVER_BASH_ALLOW=git status,ls,cat

# HTTP transport + X-Api-Key auth (stdio için gerekmez)
# MCP_SERVE_TRANSPORT=http
# MCP_SERVE_PORT=3100
# MCP_SERVE_API_KEY=degistir-beni
