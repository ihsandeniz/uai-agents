# Database
POSTGRES_USER=uai
POSTGRES_PASSWORD=uai_dev_2026
POSTGRES_DB=uai
DATABASE_URL=postgres://uai:uai_dev_2026@localhost:5434/uai

# Redis
REDIS_URL=redis://localhost:6380

# ─── LLM Sağlayıcı (BYOK — Bring Your Own Key) ────────────────────────
# Varsayılan: openrouter. Hiçbir LLM_* değişkeni set edilmezse eski davranış korunur.
#
# LLM_PROVIDER seçenekleri:
#   openrouter → OPENROUTER_API_KEY  (varsayılan)
#   openai     → OPENAI_API_KEY
#   gemini     → GEMINI_API_KEY      (Google'ın OpenAI-uyumlu endpoint'i)
#   ollama     → anahtar gerekmez, lokal (http://localhost:11434) — ücretsiz, sınırsız
#   custom     → LLM_API_KEY + LLM_BASE_URL (LM Studio / Groq / Together / vLLM)
LLM_PROVIDER=openrouter

# OpenRouter — https://openrouter.ai/keys adresinden al
OPENROUTER_API_KEY=

# Diğer sağlayıcıların anahtarları (yalnızca ilgili LLM_PROVIDER seçilirse kullanılır)
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# İleri düzey ezmeler (opsiyonel):
# LLM_BASE_URL=        # preset URL'i ez (custom/self-host proxy için)
# LLM_API_KEY=         # genel anahtar ezmesi (preset keyEnv yerine)
# LLM_MODEL=           # tüm kademeleri tek somut modele sabitle (ör: llama-3.3-70b)

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Auth & CORS
UAI_API_KEY=
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
