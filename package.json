{
  "name": "uai",
  "private": true,
  "version": "0.0.1",
  "description": "UAI Agents Team — Multi-Agent Orchestration System",
  "license": "MIT",
  "author": "İhsan Deniz Tüfekci",
  "repository": {
    "type": "git",
    "url": "https://github.com/ihsandeniz/uai-agents.git"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @uai/db generate",
    "db:migrate": "pnpm --filter @uai/db migrate",
    "db:studio": "pnpm --filter @uai/db studio",
    "setup": "node scripts/setup.mjs",
    "infra": "docker compose up postgres redis -d --wait",
    "infra:down": "docker compose down postgres redis",
    "infra:logs": "docker compose logs -f postgres redis",
    "infra:full": "docker compose up -d --wait",
    "start": "pnpm infra && pnpm db:migrate && pnpm dev",
    "lint": "pnpm -r lint",
    "test:llm": "tsx --env-file=.env scripts/test-llm.ts",
    "test:mcp": "tsx scripts/test-mcp.ts",
    "mcp:serve": "tsx scripts/uai-mcp-server.ts",
    "cli": "pnpm --filter @uai/runtime cli"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
